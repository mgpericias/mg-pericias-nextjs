# .env.local — copie este arquivo e preencha com seus valores reais.
# IMPORTANTE: NENHUMA variável aqui pode ter o prefixo NEXT_PUBLIC_.
# Todas são privadas e rodam apenas no servidor.

# Google Places API (avaliações)
GOOGLE_PLACES_API_KEY=coloque-sua-chave-aqui

# Supabase (blog + cache de avaliações)
# Pegue em: Supabase > Project Settings > API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque-sua-service-role-key-aqui

# Resend (formulário de contato)
# Pegue em: resend.com > API Keys
RESEND_API_KEY=coloque-sua-chave-aqui
